# FileWise 环境变量配置模板
# 复制此文件为 .env，填入实际值。.env 文件不会提交到 Git。

# ===== AI 模型配置 =====
# AI 运行模式: local | cloud | hybrid
AI_MODE=local

# 本地 Ollama 地址（默认无需修改）
OLLAMA_BASE_URL=http://localhost:11434

# 本地默认模型
OLLAMA_MODEL=qwen2.5:7b

# ===== 云端 API（可选，AI_MODE=cloud 时使用）=====
# OpenAI / 兼容接口
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# 通义千问（可选）
QWEN_API_KEY=
QWEN_MODEL=qwen-plus

# ===== 应用配置 =====
# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# 隔离区文件保留天数
QUARANTINE_DAYS=30
